<Window x:Class="AITraining.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Training – Load data, train, ask"
        Height="520"
        Width="640"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Data file -->
        <GroupBox Grid.Row="0" Header="1. Data file" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DataFilePathTextBox"
                             Grid.Column="0"
                             Margin="0,0,10,0"
                             IsReadOnly="True"
                             VerticalContentAlignment="Center"
                             Padding="6,4" />
                    <Button x:Name="BrowseDataFileButton"
                            Grid.Column="1"
                            Content="Browse..."
                            Padding="14,6"
                            Click="BrowseDataFileButton_Click" />
                </Grid>
                <TextBlock x:Name="DataFileStatusTextBlock"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="No file selected. CSV must have columns: Size, Rooms, Label (in that order)."
                           TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>

        <!-- Train model -->
        <GroupBox Grid.Row="1" Header="2. Train model" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>
                <Button x:Name="TrainModelButton"
                        Content="Train model on loaded data"
                        Padding="14,8"
                        HorizontalAlignment="Left"
                        IsEnabled="False"
                        Click="TrainModelButton_Click" />
                <TextBlock x:Name="TrainStatusTextBlock"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="Load a data file first."
                           TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>

        <!-- Ask (predict) -->
        <GroupBox Grid.Row="2" Header="3. Ask the model (predict)" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Size:" VerticalAlignment="Center" Margin="0,0,10,8" />
                    <TextBox x:Name="AskSizeTextBox"
                             Grid.Row="0" Grid.Column="1"
                             Margin="0,0,0,8"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="e.g. 1700 (square feet)" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Rooms:" VerticalAlignment="Center" Margin="0,0,10,8" />
                    <TextBox x:Name="AskRoomsTextBox"
                             Grid.Row="1" Grid.Column="1"
                             Margin="0,0,0,8"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="e.g. 4" />
                    <Button x:Name="PredictButton"
                            Grid.Row="2"
                            Grid.Column="1"
                            Content="Get prediction"
                            Padding="14,8"
                            HorizontalAlignment="Left"
                            IsEnabled="False"
                            Click="PredictButton_Click" />
                </Grid>
                <TextBlock x:Name="PredictionResultTextBlock"
                           Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="Enter Size and Rooms, then click Get prediction (after training)."
                           TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>

        <!-- Status / log -->
        <GroupBox Grid.Row="3" Header="Status" Padding="12,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="StatusLogTextBlock"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="12" />
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>
